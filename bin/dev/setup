#!/usr/bin/env bash

#
# SP Dashboard Developer Setup Script
#
# Installs dependencies and sets up the project for development.
#

set -e  # Exit on error

echo "Setting up SP Dashboard development environment..."
echo ""

# Get the project root directory
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$PROJECT_ROOT"

# Install PHP dependencies
echo "📦 Installing PHP dependencies..."
composer install --ignore-platform-req=ext-zip

# Install JavaScript dependencies
echo "📦 Installing JavaScript dependencies..."
yarn install

# Create .env file if it doesn't exist
if [ ! -f ".env" ]; then
    if [ -f ".env.dist" ]; then
        echo "📝 Creating .env file from .env.dist..."
        cp .env.dist .env
        echo "✓ .env created (review and customize as needed)"
    fi
fi

# Build frontend assets
echo "🔨 Building frontend assets..."
yarn encore dev

# Run database migrations (will skip if database isn't available)
echo "🗄️  Running database migrations..."
bin/console doctrine:migrations:migrate --env=dev --no-interaction 2>/dev/null || \
  echo "⚠ Database not available - run migrations manually after starting Docker"

echo ""
echo "✅ Setup complete!"
echo ""
echo "Next steps:"
echo "  • Start the app with OpenConext-devconf (see README.md)"
echo "  • Access: https://spdashboard.dev.openconext.local/"
echo "  • Run tests: composer check"
echo "  • Watch assets: yarn encore dev --watch"
